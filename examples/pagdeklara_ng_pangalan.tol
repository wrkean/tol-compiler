ang x: numero = 1              -- May data type na `numero`
ang xx = 1                     -- Pwede ding mag `infer` ang tol kung ano ang data type ng isang pangalan, kaya valid din ito

-- Sa tol, illegal ang pagpalit ng data type
x = 4.2     -- Illegal, dahil ang x ay naideklara na may `numero` na data type
xx = 1.2    -- Illegal din sa kaparehong dahilan
